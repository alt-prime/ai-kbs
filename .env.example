# （すでに設定済みのGemini APIキー）
GOOGLE_GENERATIVE_AI_API_KEY=xxxxxxxxxxxxxxx

# ダウンロードしたJSONファイルから転記
FIREBASE_PROJECT_ID=your-project-12345
FIREBASE_CLIENT_EMAIL=sauna-rag-backend@your-project-12345.iam.gserviceaccount.com

# ⚠️ 注意: private_keyは "-----BEGIN PRIVATE KEY-----\n" から "\n-----END PRIVATE KEY-----\n" までの文字列を、改行部分（\n）を含めてそのまま1行で貼り付けます。（ダブルクォーテーションで囲んでおくと安全です）
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIB... (中略) ...\n-----END PRIVATE KEY-----\n"

# バッチ処理用セキュリティシークレット（適当な推測されにくい文字列を自分で決めて入力します）
CRON_SECRET=my-super-secret-cron-key-12345

NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=